# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local overrides
.claude/settings.local.json

# Local IDE settings (in case VS Code workspace settings get committed accidentally)
.vscode/settings.json

/lib/generated/prisma

# Prisma generated client (if output path is customized)
/lib/generated/

# Claude Code worktrees
.claude/worktrees/

# Self-review hook outputs (ephemeral, regenerated on each commit)
.claude/reviews/

# Playwright MCP output (screenshots, snapshots, console logs)
.playwright-mcp/

# Working tree detritus
# Verification screenshots from Playwright runs
*.png
*.jpg
*.jpeg
*.gif

# Raw data CSVs (source data for one-time imports; not part of the repo)
*.csv
!data-import/material_normalization.csv

# LibreOffice / OpenOffice lock files
.~lock.*

# Data import session reports (timestamped log files)
data-import/import-report-*.txt

# Database dumps and ad-hoc SQL exports
*.sql

# But keep migration files
!prisma/migrations/**/*.sql