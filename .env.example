# PostgreSQL connection string (Neon for production, Neon dev branch for local dev)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=verify-full"

# Sentry DSN for error tracking (server-side)
SENTRY_DSN="https://example@o0.ingest.sentry.io/0"

# Sentry DSN for error tracking (client-side; same value as SENTRY_DSN)
NEXT_PUBLIC_SENTRY_DSN="https://example@o0.ingest.sentry.io/0"

SENTRY_AUTH_TOKEN="your-org-token-here"