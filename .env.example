# Neon database connection strings.
#
# DATABASE_URL is the POOLED connection string (host typically contains
# "-pooler"). Used by the application at runtime for query traffic. The
# pooler multiplexes connections, which is essential for serverless
# environments like Vercel where every function invocation may open a
# new connection.
#
# DIRECT_URL is the DIRECT (non-pooled) connection string. Used by the
# Prisma CLI for schema migrations (`prisma migrate deploy`). The pooler
# does not support DDL, so migrations must bypass it.
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech:5432/database?sslmode=verify-full"
DIRECT_URL="postgresql://user:password@host.neon.tech:5432/database?sslmode=verify-full"

# Sentry DSN for error tracking (server-side)
SENTRY_DSN="https://example@o0.ingest.sentry.io/0"

# Sentry DSN for error tracking (client-side; same value as SENTRY_DSN)
NEXT_PUBLIC_SENTRY_DSN="https://example@o0.ingest.sentry.io/0"

SENTRY_AUTH_TOKEN="your-org-token-here"

# Pino log level. Defaults to "info" if unset. In production, "info" is
# the right level; use "debug" temporarily when diagnosing issues.
# Valid values: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"